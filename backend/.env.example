# Required for server and tests (use these exact values for local setup)
PORT=3229
URL="http://127.0.0.1"
MONGODB_URI="mongodb://localhost:27017/babylon-nexus"

# JWT secrets (change in production)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# Optional: token TTL
# ACCESS_TOKEN_TTL_MINUTES=10
# REFRESH_TOKEN_TTL_DAYS=1

# Optional: seed first admin (run npm run seed:admin)
# ADMIN_SEED_EMAIL=admin@babylon.example.com
# ADMIN_SEED_PASSWORD=your-secure-password

# Email (Gmail SMTP) — required for invite emails
# EMAIL_USER=your-gmail@gmail.com
# EMAIL_PASS=your-gmail-app-password  # Generate at myaccount.google.com/apppasswords (requires 2FA)
